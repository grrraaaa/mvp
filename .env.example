# ─── LLM (OpenRouter — совместим с OpenAI API) ───────
# Ключ: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SberAI Assistant

# Для прямого OpenAI — оставьте OPENAI_BASE_URL пустым:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ─── LLM-нормализатор запросов (опционально) ───────────
# Переписывает «здароу браток, последние переводы» → «покажи последние переводы»
# перед основным pipeline. Дефолт включён, авто-выключается без OPENAI_API_KEY.
# Подробно: docs/ASSISTANT_COMMANDS.md § 1.1
# LLM_REF_ENABLED=1
# LLM_REF_MODEL=gpt-4o-mini
# LLM_REF_TIMEOUT=2.5
# LLM_REF_CACHE_SIZE=256
# LLM_REF_MIN_CONFIDENCE=0.6

# ─── Backend ──────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# PostgreSQL — Neon (облако, рекомендуется) или локальный Docker
# Neon: Vercel → Storage → Neon → Connect, затем `vercel env pull .env.development.local`
# POSTGRES_URL=postgresql://user:pass@...-pooler....neon.tech/neondb?sslmode=require
# POSTGRES_URL_NON_POOLING=postgresql://user:pass@....neon.tech/neondb?sslmode=require
# Локальный Docker: docker compose up -d postgres
# DATABASE_URL=postgresql+asyncpg://sber:sber@127.0.0.1:5432/sber

# Демо-логины (создаются при старте бэкенда):
# demo / demo       → DEMO ЮРИДИЧЕСКОЕ ЛИЦО
# ipivanov / ip123  → ИП ИВАНОВ (12 000 BYN)
# buhplus / buh123  → ООО БУХГАЛТЕРИЯ ПЛЮС
# На Vercel: POSTGRES_URL подставляется из Storage автоматически
ALLOWED_ORIGINS=http://localhost:3000

# ─── OCR (ImageToText.com — заполнение платежек с фото) ─
IMAGETOTEXT_API_KEY=your-api-key
IMAGETOTEXT_API_SECRET=your-api-secret

# ─── Google Cloud TTS (приоритет №1) ────────────────────
# API-ключ: https://console.cloud.google.com/apis/credentials
# Без ключа — фоллбек на Qwen → Edge.
GOOGLE_TTS_API_KEY=
# Альтернатива API-ключу — путь к JSON сервис-аккаунта
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
# Или вставьте JSON сервис-аккаунта целиком в одну строку
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_TTS_VOICE=ru-RU-Wavenet-B
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0

# ─── Qwen TTS (Alibaba Model Studio, Frankfurt EU) — фоллбек ──
# API key: Model Studio → API Key (sk-ws-...)
# Base URL: https://{workspace-id}.eu-central-1.maas.aliyuncs.com/api/v1
QWEN_TTS_API_KEY=
QWEN_TTS_BASE_URL=https://YOUR-WORKSPACE.eu-central-1.maas.aliyuncs.com/api/v1
QWEN_TTS_VOICE=qwen-male
# Модели через запятую (нужно включить в консоли Models → Speech synthesis)
QWEN_TTS_MODEL=qwen3-tts-flash,cosyvoice-v3-flash

# Голос по умолчанию в UI: ru-RU-Wavenet-B | qwen-male | ru-RU-DmitryNeural
# Фронт автоматически подбирает male/female по полу 3D-персонажа.
TTS_DEFAULT_VOICE=ru-RU-Wavenet-B
# DEEPGRAM_TTS_MODEL=aura-2-arcas-en

# ─── Inworld AI TTS (серверный стриминг, приоритет в UI) ─
# Ключ: Base64 после "Basic " (или полная строка "Basic ...")
# INWORLD_API_KEY=
# INWORLD_VOICE_MALE=merry-candle-6309__design-voice-6eaa5889
# INWORLD_VOICE_FEMALE=Ashley
# INWORLD_MODEL_ID=inworld-tts-2
# INWORLD_LANGUAGE=AUTO
# INWORLD_DELIVERY_MODE=BALANCED
# INWORLD_TTS_SPEAKING_RATE=1.0

# ─── TTS по умолчанию (gTTS — без API-ключа) ─
# TTS_PROVIDER=gtts
# GTTS_VOICE=ru-male

# ─── Frontend ─────────────────────────────────────────
# Локально — отдельный uvicorn. На Vercel оставьте пустым (тот же домен /api).
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Vercel: закрыть сайт и API паролем (ОБЯЗАТЕЛЬНО на проде) ──
SITE_ACCESS_USER=admin
SITE_ACCESS_PASSWORD=придумайте-длинный-секретный-пароль
NEXT_PUBLIC_APP_ENV=development

# ─── DB reset ──────────────────────────────────────────
# 1 = на каждом cold-start serverless снести схему и заново засеять демо-данные.
# Полезно на dev-деплоях, чтобы новые seed-данные сразу попадали в БД.
# На проде НЕ включать — снесёт реальные изменения пользователей.
RESEED_ON_DEPLOY=0
# Опциональный токен для ручного POST /api/admin/reseed (X-Admin-Token).
# Если задан — endpoint требует заголовок. Если пуст — открыт (только для демо).
# ADMIN_TOKEN=придумайте-секрет
# Пресет консультанта: banker-m | banker-f | vip | casual
NEXT_PUBLIC_CHARACTER_PRESET=banker-m
# 3D-модель консультанта (frontend/public/models/personage.glb)
NEXT_PUBLIC_CHARACTER_GLB=/models/personage.glb
NEXT_PUBLIC_CHARACTER_GLB_SCALE=1
NEXT_PUBLIC_CHARACTER_GLB_Y=0
# true = портретный режим (без ходьбы), камера далеко от модели
NEXT_PUBLIC_CHARACTER_HEAD_PORTRAIT=true
# Дистанция камеры (больше = персонаж дальше / меньше в кадре)
# NEXT_PUBLIC_PORTRAIT_CAMERA_Z=6.9
# NEXT_PUBLIC_PORTRAIT_CAMERA_Z_COMPACT=7.5
# NEXT_PUBLIC_PORTRAIT_CAMERA_FOV=36
# Смещение камеры по высоте (отрицательное = ниже)
# NEXT_PUBLIC_PORTRAIT_CAMERA_Y_OFFSET=-0.22
# NEXT_PUBLIC_PORTRAIT_TARGET_Y_OFFSET=-0.16
# NEXT_PUBLIC_CHARACTER_PORTRAIT_SCALE=3
