# ─── LLM (OpenRouter — совместим с OpenAI API) ───────
# Ключ: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SberAI Assistant

# Для прямого OpenAI — оставьте OPENAI_BASE_URL пустым:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ─── Backend ──────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# PostgreSQL (рекомендуется) — docker compose up -d postgres
DATABASE_URL=postgresql+asyncpg://sber:sber@127.0.0.1:5432/sber
# Локально без Postgres — закомментируйте DATABASE_URL (будет SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./data/sber.db

# На Vercel: POSTGRES_URL подставляется из Storage автоматически
ALLOWED_ORIGINS=http://localhost:3000

# ─── OCR (ImageToText.com — заполнение платежек с фото) ─
IMAGETOTEXT_API_KEY=your-api-key
IMAGETOTEXT_API_SECRET=your-api-secret

# ─── Frontend ─────────────────────────────────────────
# Локально — отдельный uvicorn. На Vercel оставьте пустым (тот же домен /api).
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Vercel: закрыть сайт и API паролем (ОБЯЗАТЕЛЬНО на проде) ──
SITE_ACCESS_USER=admin
SITE_ACCESS_PASSWORD=придумайте-длинный-секретный-пароль
NEXT_PUBLIC_APP_ENV=development
# Пресет консультанта: banker-m | banker-f | vip | casual
NEXT_PUBLIC_CHARACTER_PRESET=banker-m
# 3D-модель консультанта (frontend/public/models/personage.glb)
NEXT_PUBLIC_CHARACTER_GLB=/models/personage.glb
NEXT_PUBLIC_CHARACTER_GLB_SCALE=1
NEXT_PUBLIC_CHARACTER_GLB_Y=0
# true = крупный план лица, без ходьбы (для personage.glb)
NEXT_PUBLIC_CHARACTER_HEAD_PORTRAIT=true
